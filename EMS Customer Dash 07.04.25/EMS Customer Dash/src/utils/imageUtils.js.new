/**
 * Utility functions for handling images in the application
 */

/**
 * Default image to use when an image fails to load
 */
export const DEFAULT_IMAGE_DATA_URI = "data:image/svg+xml;base64,";

/**
 * Fixes common issues with S3 image URLs
 * @param {string} imgSrc - The original image URL
 * @returns {string} - The fixed image URL or default image if null/undefined
 */
export function fixS3ImageUrl(imgSrc) {
  // If image source is null, undefined, or empty string, return default image data URI
  if (!imgSrc || imgSrc === '') return DEFAULT_IMAGE_DATA_URI;
  
  // If the image is already a local path (starts with /), return as is
  if (imgSrc.startsWith('/')) return imgSrc;
  
  // If the image is a data URI, return as is
  if (imgSrc.startsWith('data:')) return imgSrc;
  
  let fixedUrl = imgSrc;
  
  try {
    // Handle double-encoded URLs
    if (fixedUrl.includes('%3A') || fixedUrl.includes('%2F')) {
      try {
        fixedUrl = decodeURIComponent(fixedUrl);
      } catch (err) {
        console.error('Error decoding URL:', err);
      }
    }
    
    // Check if URL is valid
    let isValidUrl = false;
    try {
      new URL(fixedUrl);
      isValidUrl = true;
    } catch (e) {
      // Not a valid URL, might be a relative path
      if (!fixedUrl.startsWith('/')) {
        fixedUrl = '/' + fixedUrl; // Convert to absolute path
      }
      return fixedUrl;
    }
    
    // Only proceed with URL fixes if it's a valid URL
    if (isValidUrl) {
      // Extract path if URL contains the S3 domain twice
      if (fixedUrl.includes('xpressticket.s3') && 
          (fixedUrl.includes('//xpressticket.s3') || fixedUrl.includes('https%3A//xpressticket.s3'))) {
        const urlMatch = fixedUrl.match(/https?:\/\/.*?\.amazonaws\.com\/(.+)/);
        if (urlMatch && urlMatch[1]) {
          fixedUrl = `https://xpressticket.s3.af-south-1.amazonaws.com/${urlMatch[1]}`;
        }
      }
      
      // Fix URL structure issues
      try {
        const url = new URL(fixedUrl);
        
        // Fix duplicate s3 in hostname
        if (url.hostname.includes('.s3.s3.')) {
          url.hostname = url.hostname.replace('.s3.s3.', '.s3.');
          fixedUrl = url.toString();
        }
        // Add s3 if missing
        else if (url.hostname.includes('xpressticket') && 
                url.hostname.includes('af-south-1.amazonaws.com') && 
                !url.hostname.includes('.s3.')) {
          url.hostname = url.hostname.replace('.af-south-1.amazonaws.com', '.s3.af-south-1.amazonaws.com');
          fixedUrl = url.toString();
        }
      } catch (err) {
        // If URL parsing fails, try to fix common patterns
        if (fixedUrl.includes('xpressticket.s3.s3.')) {
          fixedUrl = fixedUrl.replace('xpressticket.s3.s3.', 'xpressticket.s3.');
        }
        console.warn('Error fixing S3 URL structure:', err);
      }
    }
  } catch (err) {
    console.error('Error processing image URL:', err);
  }
  
  return fixedUrl;
}
